# ─────────────────────────────────────────────────────────────
# Firebase Web App configuration
# ─────────────────────────────────────────────────────────────
# 1. Copy this file to ".env"   →   cp .env.example .env
# 2. Firebase Console → Project settings (gear icon) → General tab
#    → "Your apps" → Web app → SDK setup and configuration → Config
# 3. Paste each value below (no quotes needed).
#
# Until these are filled in, the app runs in LOCAL DEMO MODE:
# auth is mocked and data is stored in your browser's localStorage.
# As soon as valid values are present, it switches to real
# Firebase Authentication + Cloud Firestore automatically.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
